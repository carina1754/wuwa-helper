e/echoes/s-fb762216dac7", "echo_memberships": {"경파급 (COST 1)": ["분해된 전사", "심월 인형 · 희(喜)", "안개 수존 · 몸", "안개 수존 · 머리", "불씨의 사냥꾼"], "거랑급 (COST 3)": ["안개 수존", "봉정계유"], "해일급 (COST 4)": ["천괴중루"]}, "id": "s-fb762216dac7", "sim_source": "datamine-3.5.0"}, {"name_ko": "냉철한 결단", "two_piece": "공명 스킬 피해가 12% 증가된다", "five_piece": "공명 스킬 발동 시, 자신의 응결 피해가 22.5% 증가되고, 15초간 지속된다. 공명 해방 발동 시, 자신의 공명 스킬 피해가 18% 증가되고, 5초간 지속되며, 최대 2스택 중첩이 가능하다", "icon": "/catalog/image/echoes/s-2fd9af1104a1", "echo_memberships": {"경파급 (COST 1)": ["갈기늑대 · 바람", "유령 인형 · 레프", "유령 인형 · 라잇", "미스터 매직", "쓸쓸한 아가씨", "미믹", "금석 암괴"], "거랑급 (COST 3)": ["방랑 기사", "파트리시우스 귀족", "메르카토르 귀족", "거대 인형"], "노도급 (COST 4)": ["이성(異性) 무장", "악몽 · 반디의 군세"]}, "id": "s-2fd9af1104a1", "sim_source": "datamine-3.5.0"}, {"name_ko": "뒤틀린 피안의 꿈", "two_piece": null, "five_piece": null, "icon": "/catalog/image/echoes/s-c94899cb484b", "echo_memberships": {"경파급 (COST 1)": ["페이 이그니스", "악몽 · 심판하는 전사", "악몽 · 상강의 사냥꾼"], "거랑급 (COST 3)": ["유령 인형", "악몽 · 초혼의 악사"], "노도급 (COST 4)": ["에코"], "해일급 (COST 4)": ["악몽 · 헤카테"]}, "other_pieces": {"3": "캐릭터의 공명 에너지가 0일 시, 자신의 크리티컬이 20% 증가되고, 에코 어빌리티 피해 보너스가 35% 증가된다"}, "id": "s-c94899cb484b", "sim_source": "datamine-3.5.0"}, {"name_ko": "떠오르는 구름", "two_piece": "공명 효율이 10% 증가된다", "five_piece": "반주 스킬을 사용한 후, 다음에 등장하는 공명자의 공격력이 22.5% 증가하며, 15초 동안 지속된다", "icon": "/catalog/image/echoes/s-ad87cb9d07cd", "echo_memberships": {"경파급 (COST 1)": ["분열 암괴", "아즈즈", "후슈슈", "응결 프리즘", "순회나비", "쇄아멧돼지", "결정화 전갈"], "거랑급 (COST 3)": ["거암 투사", "그린멜팅카멜레온", "화살곰", "트랜스카", "갈기늑대 · 눈꽃"], "노도급 (COST 4)": ["음험한 백로"], "해일급 (COST 4)": ["타종 거북이"]}, "id": "s-ad87cb9d07cd", "sim_source": "datamine-3.5.0"}, {"name_ko": "마음을 엮은 꿈의 그림자", "two_piece": "공격력이 10% 증가된다", "five_piece": "캐릭터가 목표에게 「조화 파동 · 이탈」 혹은 「조화 밀집 · 이탈」 추가 시, 파티 내 캐릭터의 조화도 파괴 증폭이 20 증가되고, 30초간 지속된다. 같은 이름의 효과는 중첩이 불가하다", "icon": "/catalog/image/echoes/s-8ff6c78465ff", "echo_memberships": {"경파급 (COST 1)": ["파종 호박벌", "바위 호박벌", "아이스글린트 댄서"], "거랑급 (COST 3)": ["플로라 메카 레인디어", "마이닝 메카 레인디어