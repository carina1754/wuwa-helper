# Local OpenAI-compatible multimodal LLM (llama.cpp llama-server). Empty → mock extraction.
LLM_BASE_URL=http://127.0.0.1:8080/v1
LLM_MODEL=wuwa-vlm
LLM_API_KEY=sk-local
DATABASE_URL=postgresql://postgres:<password>@127.0.0.1:5432/wuwa_ai_coach
CORS_ALLOW_ORIGINS=https://wuwahelper.com,http://localhost:3000,http://127.0.0.1:3000
DISABLE_CONTENT_REFRESH=0
# Must match frontend/.env.local's INTERNAL_API_SECRET exactly; required to call POST /auth/sync-user
INTERNAL_API_SECRET=<random-secret>